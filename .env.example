# ── Backend ───────────────────────────────────────────
PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/logicore

# Redis (for JWT blacklisting)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_before_production
TOKEN_EXPIRY_HOURS=24

# CORS — comma-separated extra origins (optional, for LAN access)
# EXTRA_ORIGINS=http://192.168.1.100:3001,http://192.168.1.100:3002

# Logging
LOG_LEVEL=info

# ── Frontend (Vite) ────────────────────────────────────
# Set in each frontend/.env file:

# frontend-driver/.env
# VITE_API_URL=http://localhost:3000
# VITE_SOCKET_URL=http://localhost:3000

# frontend-manager/.env
# VITE_API_URL=http://localhost:3000
# VITE_SOCKET_URL=http://localhost:3000

# frontend-supplier/.env
# VITE_API_URL=http://localhost:3000
# VITE_SOCKET_URL=http://localhost:3000

# frontend-gate/.env
# VITE_API_URL=http://localhost:3000
# VITE_SOCKET_URL=http://localhost:3000
